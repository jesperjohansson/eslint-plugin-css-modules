{
  "compilerOptions": {
    "target": "es6",
    "module": "NodeNext",
    "lib": ["ESNext"],
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationDir": "dist",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "alwaysStrict": true,
    "skipDefaultLibCheck": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "types": ["node"]
  },
  "exclude": ["dist", "src/fixtures", "example"]
}
